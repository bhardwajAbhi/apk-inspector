#!/usr/bin/env bash
# APK Inspector — Nautilus Script (reference copy)
# Installed to: ~/.local/share/nautilus/scripts/Get APK Details
# Access via: right-click → Scripts → Get APK Details

INSPECTOR="$HOME/.local/share/apk-inspector/apk_inspector.py"

if [[ -z "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS" ]]; then
    exit 0
fi

while IFS= read -r filepath; do
    [[ -z "$filepath" ]] && continue
    case "${filepath,,}" in
        *.apk) ;;
        *) continue ;;
    esac
    python3 "$INSPECTOR" "$filepath" &
    disown
done <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
