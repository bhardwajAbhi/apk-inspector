[Desktop Entry]
# Legacy file-manager action — not used by install.sh (v3+).
# Main menu integration uses extensions/apk_inspector_nautilus.py instead.
Type=Action
Name=Get APK Details
Icon=utilities-terminal
Tooltip=Parse and display APK metadata, permissions, signing info, and more

Profiles=profile-apk;

[X-Action-Profile profile-apk]
MimeTypes=application/vnd.android.package-archive;
SelectionCount=1
Targets=files;
Exec=python3 %h/.local/share/apk-inspector/apk_inspector.py %f
